<Window xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" x:Name="frmCTableSyntax" x:Class="DBI_Scripting.Forms.Analytics.FrmCTableSyntax"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create CTable Syntax" Height="413.333" Width="912.444" WindowStartupLocation="CenterScreen" Loaded="frmCTableSyntax_Loaded">
    <Grid>
        <Label Content="Structure Excel Path : " HorizontalAlignment="Left" Margin="10,22,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtStructureExcelPath" HorizontalAlignment="Left" Height="23" Margin="133,25,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="662"/>
        <Button x:Name="btnBrowseExcel" Content="Browse" HorizontalAlignment="Left" Margin="811,25,0,0" VerticalAlignment="Top" Width="75" Height="23" Click="btnBrowseExcel_Click"/>
        <Label Content="Banner File Path : " HorizontalAlignment="Left" Margin="28,55,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtBannerFilePath" HorizontalAlignment="Left" Height="23" Margin="133,58,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="662"/>
        <Button x:Name="btnBrowseBanner" Content="Browse" HorizontalAlignment="Left" Margin="811,58,0,0" VerticalAlignment="Top" Width="75" Height="23" Click="btnBrowseBanner_Click"/>
        <Label Content="Output File Name : " HorizontalAlignment="Left" Margin="17,90,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtOutputFileName" HorizontalAlignment="Left" Height="23" Margin="133,93,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="439"/>
        <ComboBox x:Name="comAnalysisType" HorizontalAlignment="Left" Margin="373,131,0,0" VerticalAlignment="Top" Width="199"/>
        <Label Content="Analysis Type : " HorizontalAlignment="Left" Margin="284,128,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="comBaseType" HorizontalAlignment="Left" Margin="373,391,0,0" VerticalAlignment="Top" Width="199"/>
        <Label Content="Base Type : " HorizontalAlignment="Left" Margin="302,388,0,0" VerticalAlignment="Top"/>
        <GroupBox Header="" HorizontalAlignment="Left" Margin="284,168,0,0" VerticalAlignment="Top" Height="189" Width="342">
            <Grid>
                <RadioButton x:Name="radioBtnRecodeSyntax" Content="Recode Syntax" HorizontalAlignment="Left" Margin="31,27,0,0" VerticalAlignment="Top"/>
                <RadioButton x:Name="radioBtnPctTableSyntax" Content="Table Cpt Syntax" HorizontalAlignment="Left" Margin="31,60,0,0" VerticalAlignment="Top"/>
                <RadioButton x:Name="radioTableCountSyn" Content="Table Count Syntax" HorizontalAlignment="Left" Margin="31,90,0,0" VerticalAlignment="Top"/>
                <TextBox x:Name="txtDecimalPlace" HorizontalAlignment="Left" Height="23" Margin="180,57,0,0" TextWrapping="Wrap" Text="1" VerticalAlignment="Top" Width="120" TextAlignment="Center"/>
                <Label Content="Decimal Place" HorizontalAlignment="Left" Margin="193,31,0,0" VerticalAlignment="Top"/>
            </Grid>
        </GroupBox>
        <Label Content="Analysis Type : " HorizontalAlignment="Left" Margin="284,128,0,0" VerticalAlignment="Top"/>

        <xctk:CheckListBox x:Name="chkListBoxWorksheet" HorizontalAlignment="Left" Height="182" Margin="42,175,0,0" VerticalAlignment="Top" Width="179" ItemSelectionChanged="chkListBoxWorksheet_ItemSelectionChanged"/>
        <Button x:Name="btnExecute" Content="Execute" HorizontalAlignment="Left" Margin="722,245,0,0" VerticalAlignment="Top" Width="107" Height="44" Click="btnExecute_Click"/>
        <Button x:Name="btnClose" Content="Close" HorizontalAlignment="Left" Margin="735,314,0,0" VerticalAlignment="Top" Width="88" Height="29" Click="btnClose_Click"/>
        <Label Content="Worksheet" HorizontalAlignment="Left" Margin="88,142,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnBrowseBannerFile" Content="Get Banner File" HorizontalAlignment="Left" Margin="704,93,0,0" VerticalAlignment="Top" Width="91" Height="23" Click="btnBrowseBannerFile_Click"/>
        <Button x:Name="btnBrowseGetStrucutureFile" Content="Create Structure File" HorizontalAlignment="Left" Margin="581,93,0,0" VerticalAlignment="Top" Width="118" Height="23" Click="btnBrowseGetStrucutureFile_Click"/>
        <Button Content="Button" HorizontalAlignment="Left" Height="31" Margin="722,183,0,0" VerticalAlignment="Top" Width="101" Click="Button_Click"/>

    </Grid>
</Window>
