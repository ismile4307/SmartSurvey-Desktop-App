<Window xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        x:Name="frmCTableSyntax"
        x:Class="DBI_Scripting.Forms.Analytics.FrmCTableSyntax"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create CTable Syntax"
        Height="560" Width="900"
        MinHeight="560" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="frmCTableSyntax_Loaded"
        Background="#EEF0F4">

    <Window.Resources>

        <!-- Blue primary button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A4F8C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#153E70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared label style -->
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <!-- White card panel -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- Section heading text -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Input files card -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             INPUT FILES CARD
        ══════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Input Files"/>
                <Separator Background="#E5E7EB" Margin="0,0,0,10"/>

                <!-- SPSS Data File -->
                <Grid Height="28" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="SPSS Data File :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtSpssDataFile" VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="3" x:Name="btnBrowseSpss" Content="Browse" Height="28" Click="btnBrowseSpss_Click"/>
                </Grid>

                <!-- Structure Excel -->
                <Grid Height="28" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Structure Excel :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtStructureExcelPath" VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="3" x:Name="btnBrowseExcel" Content="Browse" Height="28" Click="btnBrowseExcel_Click"/>
                </Grid>

                <!-- Banner File -->
                <Grid Height="28" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Banner File :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtBannerFilePath" VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="3" x:Name="btnBrowseBanner" Content="Browse" Height="28" Click="btnBrowseBanner_Click"/>
                </Grid>

                <!-- Output File Name + action buttons -->
                <Grid Height="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="132"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="108"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Output File Name :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtOutputFileName" VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="3" x:Name="btnBrowseGetStrucutureFile" Content="Create Structure File" Height="28" Click="btnBrowseGetStrucutureFile_Click"/>
                    <Button Grid.Column="5" x:Name="btnBrowseBannerFile" Content="Get Banner File" Height="28" Click="btnBrowseBannerFile_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════
             MAIN CONTENT
        ══════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="195"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Worksheet list -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Worksheet"/>
                        <Separator Background="#E5E7EB"/>
                    </StackPanel>
                    <xctk:CheckListBox Grid.Row="1" x:Name="chkListBoxWorksheet"
                                       BorderThickness="0"
                                       ItemSelectionChanged="chkListBoxWorksheet_ItemSelectionChanged"/>
                </Grid>
            </Border>

            <!-- Right panel: Analysis Type (top) + Syntax Type (bottom, stretches) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Analysis Type card -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>      <!-- Syntax Type card -->
                </Grid.RowDefinitions>

                <!-- Analysis Type card -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Analysis Type" VerticalAlignment="Center"
                                   FontWeight="SemiBold" Foreground="#374151" FontSize="12"/>
                        <ComboBox Grid.Column="2" x:Name="comAnalysisType" Height="26" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Syntax Type card -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Syntax Type"/>
                            <Separator Background="#E5E7EB"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <RadioButton x:Name="radioBtnRecodeSyntax"    Content="Recode Syntax"        Margin="0,8"/>
                                <RadioButton x:Name="radioBtnPctTableSyntax"  Content="Table Cpt Syntax"     Margin="0,8"/>
                                <RadioButton x:Name="radioBtnPct2TableSyntax" Content="Table Cpt (%) Syntax" Margin="0,8"/>
                                <RadioButton x:Name="radioTableCountSyn"      Content="Table Count Syntax"   Margin="0,8"/>
                            </StackPanel>

                            <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1"
                                    CornerRadius="4" Padding="12,10" VerticalAlignment="Center" Margin="10,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Decimal Place" FontWeight="SemiBold" FontSize="11"
                                               Foreground="#555" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox x:Name="txtDecimalPlace" Width="72" Height="30" Text="1"
                                             TextAlignment="Center" VerticalContentAlignment="Center"
                                             FontSize="14" BorderBrush="#C0C5CC"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════
             FOOTER
        ══════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White" BorderBrush="#D1D5DB" BorderThickness="1"
                CornerRadius="6" Padding="16,10">
            <Grid>
                <Button x:Name="btnHelp" Content="Help" Width="88" Height="34"
                        HorizontalAlignment="Left" Click="btnHelp_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="Execute" Width="110" Height="34"
                            Margin="0,0,8,0" Style="{StaticResource PrimaryBtn}" Click="btnExecute_Click"/>
                    <Button x:Name="btnClose" Content="Close" Width="88" Height="34" Click="btnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
