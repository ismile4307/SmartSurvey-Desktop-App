<Window x:Class="DBI_Scripting.Forms.Analytics.FrmSummaryTableSyntax"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Summary Table Syntax"
        Height="580" Width="960"
        MinHeight="480" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Background="#EEF0F4">

    <Window.Resources>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A4F8C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#153E70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#93B4D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C0C5CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>

        <Style x:Key="PanelCaption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="8,4,0,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14,10,14,10">
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Title -->
                    <RowDefinition Height="Auto"/>  <!-- Separator -->
                    <RowDefinition Height="28"/>    <!-- Var Def File -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="28"/>    <!-- SAV File -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>     <!-- Main panels -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="14"/>    <!-- Progress bar -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>  <!-- Status + Buttons -->
                </Grid.RowDefinitions>

                <!-- Title + Help button -->
                <Grid Grid.Row="0">
                    <TextBlock Text="Summary Table Syntax" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnHelp" Content="? Format"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="22" Padding="8,0"
                            Style="{StaticResource SecondaryBtn}"
                            Click="btnHelp_Click"/>
                </Grid>
                <Separator Grid.Row="1" Background="#D1D5DB" Margin="0,0,0,10"/>

                <!-- Variable Def File row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Variable Def File :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtVarDefPath"
                             VerticalContentAlignment="Center" Padding="5,0" IsReadOnly="True"/>
                    <Button Grid.Column="3" x:Name="btnBrowseVarDef" Content="Browse"
                            Height="28" Style="{StaticResource SecondaryBtn}"
                            Click="btnBrowseVarDef_Click"/>
                </Grid>

                <!-- SPSS SAV File row -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="SPSS SAV File :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtSavPath"
                             VerticalContentAlignment="Center" Padding="5,0" IsReadOnly="True"/>
                    <Button Grid.Column="3" x:Name="btnBrowseSav" Content="Browse"
                            Height="28" Style="{StaticResource SecondaryBtn}"
                            Click="btnBrowseSav_Click"/>
                </Grid>

                <!-- Main content: Parsed Sets | Generated Syntax -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Parsed Sets panel -->
                    <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Parsed Sets" Style="{StaticResource PanelCaption}"/>
                            <ListBox Grid.Row="1" x:Name="lstSets"
                                     Margin="4,2,4,4"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="11" FontFamily="Segoe UI"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>

                    <!-- Generated Syntax panel -->
                    <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Generated Syntax" Style="{StaticResource PanelCaption}"/>
                            <TextBox Grid.Row="1" x:Name="txtSyntax"
                                     Margin="4,2,4,4"
                                     FontFamily="Consolas" FontSize="11"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Visible"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="Transparent" BorderThickness="0"
                                     TextWrapping="NoWrap"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Progress bar -->
                <ProgressBar Grid.Row="8" x:Name="progressBar1" Minimum="0" Maximum="100" Value="0"/>

                <!-- Status + Buttons -->
                <Grid Grid.Row="10">
                    <TextBlock x:Name="lblStatus"
                               VerticalAlignment="Center"
                               FontSize="11" Foreground="#555"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,280,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnGenerate" Content="Generate"
                                Width="88" Height="30" Margin="0,0,8,0"
                                Style="{StaticResource PrimaryBtn}"
                                Click="btnGenerate_Click"/>
                        <Button x:Name="btnSaveSPS" Content="Save SPS"
                                Width="88" Height="30" Margin="0,0,8,0"
                                IsEnabled="False"
                                Style="{StaticResource SecondaryBtn}"
                                Click="btnSaveSPS_Click"/>
                        <Button x:Name="btnClose" Content="Close"
                                Width="78" Height="30"
                                Style="{StaticResource SecondaryBtn}"
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
