<Window x:Class="DBI_Scripting.Forms.Analytics.FrmCTableLink2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set CTable Link"
        Height="340" Width="820"
        MinHeight="310" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Background="#EEF0F4">

    <Window.Resources>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A4F8C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#153E70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#93B4D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C0C5CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>

        <Style x:Key="PanelCaption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="8,4,0,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14,10,14,10">
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Title -->
                    <RowDefinition Height="Auto"/>  <!-- Separator -->
                    <RowDefinition Height="Auto"/>  <!-- Excel path -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Sheet names -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Settings panels -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="14"/>    <!-- Progress bar -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>  <!-- Status + Buttons -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="Custom Table Link" Style="{StaticResource SectionTitle}"/>
                <Separator Grid.Row="1" Background="#D1D5DB" Margin="0,0,0,10"/>

                <!-- Excel file path -->
                <Grid Grid.Row="2" Height="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Table Excel File :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtAnalysisExcelPath"
                             VerticalContentAlignment="Center" Padding="5,0" IsReadOnly="True"/>
                    <Button Grid.Column="3" x:Name="btnBrowseExcel" Content="Browse"
                            Height="28" Style="{StaticResource SecondaryBtn}"
                            Click="btnBrowseExcel_Click"/>
                </Grid>

                <!-- Sheet names row -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Table sheet -->
                    <Grid Grid.Column="0" Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Table Sheet Name :" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1" x:Name="txtTableSheetName"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="5,0"/>
                    </Grid>

                    <!-- Link sheet -->
                    <Grid Grid.Column="2" Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Link Sheet Name :" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1" x:Name="txtLinkSheetName"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="5,0"/>
                    </Grid>
                </Grid>

                <!-- Settings panels row -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Index Start -->
                    <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Index Start" Style="{StaticResource PanelCaption}"/>
                            <Grid Grid.Row="1" Margin="8,4,8,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Row :" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtRowNo"
                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                <Label Grid.Row="2" Grid.Column="0" Content="Column :" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtColumnNo"
                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Link Format -->
                    <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Link Format" Style="{StaticResource PanelCaption}"/>
                            <ComboBox Grid.Row="1" x:Name="comLinkFormat"
                                      Margin="8,4,8,8" Height="28"
                                      VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Table Mode -->
                    <Border Grid.Column="4" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Table Mode" Style="{StaticResource PanelCaption}"/>
                            <StackPanel Grid.Row="1" Margin="12,6,8,8" Orientation="Vertical">
                                <RadioButton x:Name="radioTableTitle" Content="Table Title"
                                             FontSize="12" Margin="0,0,0,6"/>
                                <RadioButton x:Name="radioTableIndex" Content="Table Index"
                                             FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Progress bar -->
                <ProgressBar Grid.Row="8" x:Name="progressBar1" Minimum="0" Maximum="100" Value="0"/>

                <!-- Status + Buttons -->
                <Grid Grid.Row="10">
                    <TextBlock x:Name="lblStatus"
                               VerticalAlignment="Center"
                               FontSize="11" Foreground="#555"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,200,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnRun" Content="Run"
                                Width="88" Height="30" Margin="0,0,8,0"
                                Style="{StaticResource PrimaryBtn}"
                                Click="btnRun_Click"/>
                        <Button x:Name="btnClose" Content="Close"
                                Width="78" Height="30"
                                Style="{StaticResource SecondaryBtn}"
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Hidden button — kept for code-behind compatibility -->
                <Button x:Name="btnDeleteDummyRow" Visibility="Collapsed"
                        Click="btnDeleteDummyRow_Click"/>

            </Grid>
        </Border>
    </Grid>
</Window>
