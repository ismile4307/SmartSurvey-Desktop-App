<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" x:Class="DBI_Scripting.Forms.Analytics.FrmTransposeSyntax"
        Title="Transpose &amp; Table Syntax" Height="502" Width="866.136" WindowStartupLocation="CenterScreen">
    <Grid Margin="0,1,0.333,-0.667">
        <GroupBox HorizontalAlignment="Left" Margin="27,10,0,0" VerticalAlignment="Top" Height="184" Width="809">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Imagery Transpose &amp; Table Syntax" VerticalAlignment="Center"/>
                    <Button x:Name="btnImageHelp" Content="?" Width="18" Height="18" Margin="6,0,0,0" FontWeight="Bold" ToolTip="Click for file format help" Click="btnImageHelp_Click"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Label Content="Image Var Path :" HorizontalAlignment="Left" Margin="12,11,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.813,-0.45" Width="96"/>
                <TextBox x:Name="txtImageVarFile" HorizontalAlignment="Left" Height="23" Margin="114,13,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="575"/>
                <Button x:Name="btnBrowseImage" Content="Browse" HorizontalAlignment="Left" Margin="712,13,0,0" VerticalAlignment="Top" Height="22" Width="75" Click="btnBrowseImage_Click" />
                <Label Content="SPSS Dataset :" HorizontalAlignment="Left" Margin="12,43,0,0" VerticalAlignment="Top" Width="96"/>
                <TextBox x:Name="txtImageSpssFile" HorizontalAlignment="Left" Height="23" Margin="114,45,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="575"/>
                <Button x:Name="btnBrowseImageSpss" Content="Browse" HorizontalAlignment="Left" Margin="712,45,0,0" VerticalAlignment="Top" Height="22" Width="75" Click="btnBrowseImageSpss_Click" />
                <Button x:Name="btnRunTranspose" Content="Run" HorizontalAlignment="Left" Margin="354,116,0,0" VerticalAlignment="Top" Width="111" Height="33" Click="btnRunTranspose_Click" />
            </Grid>
        </GroupBox>
        <GroupBox HorizontalAlignment="Left" Margin="27,207,0,0" VerticalAlignment="Top" Height="176" Width="809">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Rank Transpose &amp; Table Syntax" VerticalAlignment="Center"/>
                    <Button x:Name="btnRankHelp" Content="?" Width="18" Height="18" Margin="6,0,0,0" FontWeight="Bold" ToolTip="Click for file format help" Click="btnRankHelp_Click"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35*"/>
                    <ColumnDefinition Width="762*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Rank Var Path :" HorizontalAlignment="Left" Margin="12,11,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.813,-0.45" Width="96" Grid.ColumnSpan="2"/>
                <TextBox x:Name="txtRankFile" HorizontalAlignment="Left" Height="23" Margin="79,13,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="575" Grid.Column="1"/>
                <Button x:Name="btnBrowseRank" Content="Browse" HorizontalAlignment="Left" Margin="677,13,0,0" VerticalAlignment="Top" Height="22" Width="75" Click="btnBrowseRank_Click" Grid.Column="1" />
                <Label Content="SPSS Dataset :" HorizontalAlignment="Left" Margin="12,43,0,0" VerticalAlignment="Top" Width="96" Grid.ColumnSpan="2"/>
                <TextBox x:Name="txtSpssFile" HorizontalAlignment="Left" Height="23" Margin="79,45,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="575" Grid.Column="1"/>
                <Button x:Name="btnBrowseSpss" Content="Browse" HorizontalAlignment="Left" Margin="677,45,0,0" VerticalAlignment="Top" Height="22" Width="75" Click="btnBrowseSpss_Click" Grid.Column="1" />
                <Button x:Name="btnRunRank" Content="Run" HorizontalAlignment="Left" Margin="318.667,106,0,0" VerticalAlignment="Top" Width="111" Height="33" Grid.Column="1" Click="btnRunRank_Click" />
            </Grid>
        </GroupBox>
        <Button x:Name="btnExit" Content="Exit" HorizontalAlignment="Left" Margin="406,406,0,0" VerticalAlignment="Top" Height="22" Width="75" RenderTransformOrigin="0.285,-1.116" Click="btnExit_Click" />

    </Grid>
</Window>
