<Window x:Class="DBI_Scripting.Forms.Settings.FrmCheckScript"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBI_Scripting.Forms.Settings"
        mc:Ignorable="d"
        Title="Check Script" Height="620" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>

        <!-- Status bar pinned to the bottom -->
        <StatusBar DockPanel.Dock="Bottom" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="progressBar"
                             Width="160" Height="14"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12,12,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Script 1 -->
            <DockPanel Grid.Row="0">
                <Label Content="Script 1 :" Width="70" VerticalAlignment="Center"/>
                <Button x:Name="btnBrowse1" Content="Browse" Width="75" Height="26"
                        DockPanel.Dock="Right" Margin="4,0,0,0"
                        Click="btnBrowse1_Click"/>
                <TextBox x:Name="txtScript1" Height="26" IsReadOnly="True"
                         VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Row 2: Script 2 -->
            <DockPanel Grid.Row="2">
                <Label Content="Script 2 :" Width="70" VerticalAlignment="Center"/>
                <Button x:Name="btnBrowse2" Content="Browse" Width="75" Height="26"
                        DockPanel.Dock="Right" Margin="4,0,0,0"
                        Click="btnBrowse2_Click"/>
                <TextBox x:Name="txtScript2" Height="26" IsReadOnly="True"
                         VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Row 4: Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnExecute" Content="Execute" Width="100" Height="30"
                        Margin="0,0,8,0" Click="btnExecute_Click"/>
                <Button x:Name="btnClose" Content="Close" Width="100" Height="30"
                        Click="btnClose_Click"/>
            </StackPanel>

            <!-- Row 6: Result output -->
            <GroupBox Grid.Row="6" Header="Comparison Result">
                <RichTextBox x:Name="txtResult"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="6"/>
            </GroupBox>

        </Grid>
    </DockPanel>
</Window>
