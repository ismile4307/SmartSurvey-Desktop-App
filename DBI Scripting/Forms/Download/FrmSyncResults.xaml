<Window x:Class="DBI_Scripting.Forms.Download.FrmSyncResults"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Results" Height="450" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label x:Name="lblSummary" Grid.Row="0" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>

        <TextBox x:Name="txtResults" Grid.Row="1"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"
                 Background="#F5F5F5" BorderThickness="1" Padding="6"
                 VerticalAlignment="Stretch"/>

        <Button x:Name="btnClose" Grid.Row="2" Content="Close" Width="80" HorizontalAlignment="Right"
                Margin="0,10,0,0" Height="26" Click="btnClose_Click"/>
    </Grid>
</Window>
