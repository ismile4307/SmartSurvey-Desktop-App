<Window x:Class="DBI_Scripting.Forms.FrmDownloadData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download Data"
        Height="530" Width="920"
        MinHeight="460" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Icon="/Smart Survey;component/Images/download_48.png"
        Background="#EEF0F4">

    <Window.Resources>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A4F8C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#153E70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#93B4D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C0C5CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>

        <Style x:Key="PanelCaption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="8,4,0,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14,10,14,10">
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Title -->
                    <RowDefinition Height="Auto"/>   <!-- Separator -->
                    <RowDefinition Height="28"/>     <!-- Project + Dates -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="28"/>     <!-- Interview + Consider + File type -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="28"/>     <!-- Save location -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>   <!-- Download script checkbox -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>      <!-- Log panel -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="14"/>     <!-- Progress bar -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- Status + Buttons -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="Download Data" Style="{StaticResource SectionTitle}"/>
                <Separator Grid.Row="1" Background="#D1D5DB" Margin="0,0,0,10"/>

                <!-- Row: Project Name + Date From + Date To -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Project Name :" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="comProjectName"
                              VerticalContentAlignment="Center"
                              SelectionChanged="comProjectName_SelectionChanged"
                              DropDownClosed="comProjectName_DropDownClosed"/>
                    <Label Grid.Column="3" Content="Date From :" Style="{StaticResource FieldLabel}"/>
                    <DatePicker Grid.Column="4" x:Name="dtpDateFrom" VerticalContentAlignment="Center"/>
                    <Label Grid.Column="6" Content="Date To :" Style="{StaticResource FieldLabel}"/>
                    <DatePicker Grid.Column="7" x:Name="dtpDateTo" VerticalContentAlignment="Center"/>
                </Grid>

                <!-- Row: Interview Type + Consider Date + File Type -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Interview Type :" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="comInterviewType" VerticalContentAlignment="Center"/>
                    <Label Grid.Column="3" Content="Consider Date :" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Column="4" x:Name="comConsiderDate" VerticalContentAlignment="Center"/>
                    <Label Grid.Column="6" Content="File Type :" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Column="7" x:Name="comFileType" VerticalContentAlignment="Center"/>
                </Grid>

                <!-- Row: Save Location -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Save Location :" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtSaveLocation"
                             VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="3" x:Name="btnBrowse" Content="Browse"
                            Height="28" Style="{StaticResource SecondaryBtn}"
                            Click="btnBrowse_Click"/>
                </Grid>

                <!-- Download Script checkbox -->
                <CheckBox Grid.Row="8" x:Name="chkDownloadScript"
                          Content="Re-download project script from server"
                          VerticalAlignment="Center" Foreground="#374151" FontSize="11"/>

                <!-- Log panel -->
                <Border Grid.Row="10" Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Activity Log" Style="{StaticResource PanelCaption}"/>
                        <TextBox Grid.Row="1" x:Name="txtLog"
                                 Margin="4,2,4,4"
                                 FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Visible"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0"
                                 TextWrapping="NoWrap"/>
                    </Grid>
                </Border>

                <!-- Progress bar -->
                <ProgressBar Grid.Row="12" x:Name="progressBar1" Minimum="0" Maximum="100" Value="0"/>

                <!-- Status + Buttons -->
                <Grid Grid.Row="14">
                    <TextBlock x:Name="lblCurrentOperation"
                               VerticalAlignment="Center"
                               FontSize="11" Foreground="#555"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,290,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnCancel" Content="Cancel"
                                Width="78" Height="30" Margin="0,0,8,0"
                                IsEnabled="False"
                                Style="{StaticResource DangerBtn}"
                                Click="btnCancel_Click"/>
                        <Button x:Name="btnExecute" Content="Execute"
                                Width="98" Height="30" Margin="0,0,8,0"
                                Style="{StaticResource PrimaryBtn}"
                                Click="btnExecute_Click"/>
                        <Button x:Name="btnExit" Content="Close"
                                Width="78" Height="30"
                                Style="{StaticResource SecondaryBtn}"
                                Click="btnExit_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Hidden — kept for code-behind compatibility -->
                <TextBox x:Name="txtServerAddress" Visibility="Collapsed"/>

            </Grid>
        </Border>
    </Grid>
</Window>
