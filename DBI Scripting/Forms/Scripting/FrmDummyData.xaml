<Window x:Class="DBI_Scripting.Forms.Scripting.FrmDummyData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dummy Data Generator" Height="540" Width="920"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="15,12,15,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>  <!-- Row 0: Project Name + Version -->
            <RowDefinition Height="32"/>  <!-- Row 1: Script Path -->
            <RowDefinition Height="32"/>  <!-- Row 2: Output Folder -->
            <RowDefinition Height="36"/>  <!-- Row 3: No. of Records + Routing -->
            <RowDefinition Height="24"/>  <!-- Row 4: Progress Bar -->
            <RowDefinition Height="22"/>  <!-- Row 5: Status Label -->
            <RowDefinition Height="*"/>   <!-- Row 6: Log TextBox -->
            <RowDefinition Height="36"/>  <!-- Row 7: Buttons -->
        </Grid.RowDefinitions>

        <!-- Row 0: Project Name + Script Version -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Project :" Width="60" FontWeight="SemiBold"/>
            <TextBox x:Name="txtProjectName" Width="280" Height="22" IsReadOnly="True"
                     Background="#F5F5F5" VerticalContentAlignment="Center" FontSize="13"/>
            <Label Content="Version :" Width="65" Margin="20,0,0,0" FontWeight="SemiBold"/>
            <TextBox x:Name="txtScriptVersion" Width="120" Height="22" IsReadOnly="True"
                     Background="#F5F5F5" VerticalContentAlignment="Center" FontSize="13"/>
        </StackPanel>

        <!-- Row 1: Script Path -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Script DB :" Width="70" FontWeight="SemiBold"/>
            <TextBox x:Name="txtScriptPath" Width="700" Height="23"
                     VerticalContentAlignment="Center" IsReadOnly="True" Background="#F5F5F5"/>
            <Button x:Name="btnBrowse" Content="Browse" Width="75" Height="23"
                    Margin="10,0,0,0" Click="btnBrowse_Click"/>
        </StackPanel>

        <!-- Row 2: Output Folder -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Output :" Width="70" FontWeight="SemiBold"/>
            <TextBox x:Name="txtOutputFolder" Width="700" Height="23"
                     VerticalContentAlignment="Center"/>
            <Button x:Name="btnBrowseOutput" Content="Browse" Width="75" Height="23"
                    Margin="10,0,0,0" Click="btnBrowseOutput_Click"/>
        </StackPanel>

        <!-- Row 3: No. of Records + Follow Routing -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Records :" Width="70" FontWeight="SemiBold"/>
            <TextBox x:Name="txtNumberOfData" Width="80" Height="24"
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                     FontSize="13"/>
            <CheckBox x:Name="chkFollowRouting" Content="Follow Routing Logic"
                      Margin="30,0,0,0" VerticalAlignment="Center" FontSize="13"/>
        </StackPanel>

        <!-- Row 4: Progress Bar -->
        <Grid Grid.Row="4">
            <ProgressBar x:Name="progressBar" Height="18" Minimum="0" Maximum="100"
                         VerticalAlignment="Center"/>
            <TextBlock x:Name="txtProgress" HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="11" Foreground="Black"/>
        </Grid>

        <!-- Row 5: Status Label -->
        <Label x:Name="lblStatus" Grid.Row="5" Content="Ready."
               FontSize="11" Foreground="#333333" Padding="2,0"/>

        <!-- Row 6: Log TextBox -->
        <TextBox x:Name="txtLog" Grid.Row="6" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11" Background="#1E1E1E" Foreground="#D4D4D4"
                 Margin="0,4,0,4" Padding="6"/>

        <!-- Row 7: Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="btnGenerate" Content="Generate Dummy Data"
                    Width="160" Height="28" FontWeight="SemiBold" Margin="0,0,20,0"
                    Click="btnGenerate_Click" Background="#0078D7" Foreground="White"/>
            <Button x:Name="btnExit" Content="Exit" Width="80" Height="28"
                    Click="btnExit_Click"/>
        </StackPanel>
    </Grid>
</Window>
