<Window x:Class="DBI_Scripting.Forms.Scripting.FrmBuildScript"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Survey — Build Script"
        Height="580" Width="880"
        MinHeight="480" MinWidth="660"
        WindowStartupLocation="CenterScreen"
        Loaded="frmBuildScript_Loaded">

    <DockPanel>

        <!-- Status bar pinned to the bottom -->
        <StatusBar DockPanel.Dock="Bottom" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="progressBar"
                             Width="160" Height="14"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content area -->
        <Grid Margin="12,12,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Configuration section ── -->
            <GroupBox Grid.Row="0" Header="Script Configuration" Padding="10,6,10,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="105"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="85"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Content="Script File :"
                           VerticalAlignment="Center"/>
                    <TextBox x:Name="txtScriptPath"
                             Grid.Row="0" Grid.Column="1"
                             Height="26" Margin="4,0"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="btnBrowse"
                            Grid.Row="0" Grid.Column="2"
                            Content="Browse..."
                            Height="26"
                            Click="btnBrowse_Click"/>

                    <Label Grid.Row="2" Grid.Column="0"
                           Content="Shell DB Type :"
                           VerticalAlignment="Center"/>
                    <ComboBox x:Name="comShellDBType"
                              Grid.Row="2" Grid.Column="1"
                              Height="26" Margin="4,0"
                              HorizontalAlignment="Left"
                              Width="230"
                              VerticalContentAlignment="Center"/>
                </Grid>
            </GroupBox>

            <!-- ── Action buttons ── -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="btnExecute"
                        Content="▶  Execute Build"
                        Width="130" Height="32"
                        Margin="0,0,6,0"
                        Click="btnExecute_Click"/>
                <Button x:Name="btnUpload"
                        Content="↑  Upload to Server"
                        Width="145" Height="32"
                        Margin="0,0,6,0"
                        IsEnabled="False"
                        Click="btnUpload_Click"/>
                <Button x:Name="btnExit"
                        Content="Close"
                        Width="75" Height="32"
                        Click="btnExit_Click"/>
            </StackPanel>

            <!-- ── Build output ── -->
            <GroupBox Grid.Row="4" Header="Build Output">
                <RichTextBox x:Name="txtBuildResult"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="6"/>
            </GroupBox>

        </Grid>
    </DockPanel>
</Window>
